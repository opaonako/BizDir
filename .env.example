# BizDir — Environment Variables
# Copy this file to .env and fill in your values.

# ── Telnyx (Telephony) ───────────────────────────────────
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_APP_ID=

# ── AI / Voice ────────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# ── Cloudflare R2 (Audio Storage) ─────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bizdir-audio
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Google Sheets Backend ──────────────────────────────────
APPS_SCRIPT_URL=
INTERNAL_SECRET=

# ── Local AI Orchestrator (optional) ───────────────────────
# Set this to your ngrok URL to route AI calls through a local orchestrator
# ORCHESTRATOR_URL=https://abc123.ngrok-free.app
