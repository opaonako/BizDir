{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/voice/webhook.js": { "runtime": "nodejs20.x", "maxDuration": 60 },
    "api/voice/call.js":    { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/voice/token.js":   { "runtime": "nodejs20.x", "maxDuration": 15 },
    "api/auth.js":          { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/listings.js":      { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/listing.js":       { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/categories.js":    { "runtime": "nodejs20.x", "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/pages/:page", "destination": "/pages/:page.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}