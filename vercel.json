{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/voice/webhook.js": { "maxDuration": 60 },
    "api/voice/call.js":    { "maxDuration": 30 },
    "api/voice/token.js":   { "maxDuration": 15 },
    "api/auth.js":          { "maxDuration": 30 },
    "api/listings.js":      { "maxDuration": 30 },
    "api/listing.js":       { "maxDuration": 30 },
    "api/categories.js":    { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/pages/:page", "destination": "/pages/:page.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
  {
  "dependencies": {
    "@telnyx/webrtc": "^2.17.0"
  }
}
}