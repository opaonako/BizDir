{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/pages/:page", "destination": "/pages/:page.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}